<!DOCTYPE html>
<html lang="nl">
<head>
  <meta charset="UTF-8" />
  <title>Boeking Bon - <%= boeking.ref %></title>
  <style>
    /* ========== RESET ========== */
    *, *::before, *::after { box-sizing: border-box; }
    html, body { margin: 0; padding: 0; }
    body {
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      font-size: 14px;
      color: #222;
      background: #f2f4f7;           /* lichte grijs enkel voor scherm */
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }

    /* ========== LAY-OUT (SCHERM) ========== */
    .page {
      width: 900px;                  /* vaste breedte, PDF blijft netjes */
      margin: 24px auto;
      background: #fff;
      border: 1px solid #ddd;
      border-radius: 12px;
      box-shadow: 0 4px 16px rgba(0,0,0,.08);
      padding: 36px 44px;
    }

    header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 22px;
    }
    header img {
      height: 60px;
      object-fit: contain;
    }

    /* Ref/Title block */
    .ref-block {
      background: #e6f0fb;
      border-left: 5px solid #0284c7;
      padding: 16px 20px;
      border-radius: 8px;
      margin-bottom: 22px;
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
    }
    .ref-block strong {
      font-size: 18px; color: #0b3558;
    }
    .ref-block small {
      display: block; font-size: 12px; color: #4b5563; margin-top: 4px;
    }

    .row { display: flex; gap: 20px; margin-bottom: 22px; }
    .info-block {
      flex: 1;
      background: #fafafa;
      border: 1px solid #e2e8f0;
      padding: 16px 18px;
      border-radius: 10px;
    }
    .info-block strong { display:block; color:#0b3558; margin-bottom:6px; }

    /* Tabel */
 /* ========== TABEL ========== */
table {
  width: 100%;
  border-collapse: collapse;
  margin-top: 14px;
  table-layout: fixed; /* vaste kolombreedtes */
}

thead tr {
  background: #0284c7;
  color: #fff;
  -webkit-print-color-adjust: exact;
  print-color-adjust: exact;
}

th, td {
  padding: 12px 16px;
  border-bottom: 1px solid #e5e7eb;
}

th {
  font-weight: 600;
  text-align: left;
  font-size: 13px;
  letter-spacing: .3px;
}

/* kolom uitlijning */
th:nth-child(1),
td:nth-child(1) {
  width: 60%;
  text-align: left;
}

th:nth-child(2),
td:nth-child(2) {
  width: 15%;
  text-align: center;
}

th:nth-child(3),
td:nth-child(3) {
  width: 25%;
  text-align: left;
}

/* zebra effect */
tbody tr:nth-child(even) {
  background: #f9fafb;
}

tbody tr:last-child td {
  border-bottom: none;
}
.qty {
  text-align: center;
  font-variant-numeric: tabular-nums;
}
    footer {
      text-align: center;
      font-size: 11px;
      color: #555;
      margin-top: 32px;
      padding-top: 10px;
      border-top: 1px solid #e5e7eb;
      line-height: 1.4;
    }

    /* ========== PRINT/PDF ========== */
    @page {
      size: A4;               /* A4 pagina */
      margin: 18mm 14mm;      /* nette printermarges */
    }
    @media print {
      html, body { background: #fff !important; } /* geen grijze achtergrond in PDF */
      .page {
        width: auto;
        margin: 0;
        border: none !important;
        border-radius: 0 !important;
        box-shadow: none !important;
        padding: 0;           /* marges komen van @page */
      }

      /* Binnenkader voor inhoud met dezelfde marges als 'screen' */
      .content {
        padding: 0; /* we gebruiken @page marges */
      }

      /* Zorg dat kleuren echt afdrukken */
      * { -webkit-print-color-adjust: exact; print-color-adjust: exact;}

      /* Tabelkop herhalen op elke nieuwe pagina */
      thead { display: table-header-group; }
      tfoot { display: table-footer-group; }

      /* Mooie page-breaks */
      header, .ref-block, .row, table, footer { page-break-inside: avoid; }
      table { page-break-after: auto; }
      tr    { page-break-inside: avoid; page-break-after: auto; }

      /* Schaduwen en hover niet printen */
      tbody tr:hover { background: transparent !important; }

      .ref-block { background: #e6f0fb !important; border-color: #0284c7 !important; }
      thead tr   { background: #0284c7 !important; color: #fff !important; }
    }
    .opmerking-blok {
  margin-top: 28px;   
  padding-top: 6px;
}

.opmerking-blok strong {
  display: block;
  margin-bottom: 6px;
  color: #0b3558;
}

.opmerking {
  white-space: pre-line; 
  line-height: 1.5;
  color: #374151;
}
  </style>
</head>
<body>
  <div class="page">
    <div class="content">
      <div class="ref-block">
        <strong>REF: <%= boeking.ref %> / <%= boeking.klant?.naam || '' %></strong>
        <small><%= boeking.beginDatumFormatted %> - <%= boeking.eindDatumFormatted %></small>
      </div>

      <div class="row">
        <div class="info-block">
          <strong>Leveringsadres:</strong>
          <% const l = boeking.leverAdresDetails || {}; %>
          <div><%= l.naam || '-' %></div>
          <div><%= l.straat || '-' %> <%= l.huisnummer || '' %></div>
          <div><%= l.postcode || '-' %> <%= l.gemeente || '' %></div>
        </div>
        <div class="info-block">
          <strong>Factuuradres:</strong>
          <% const f = boeking.klant?.factuurAdres || {}; %>
          <div><%= boeking.klant?.naam || '-' %></div>
          <div><%= f.straat || '-' %> <%= f.huisnummer || '' %></div>
          <div><%= f.postcode || '-' %> <%= f.gemeente || '' %></div>
        </div>
      </div>

      <table>
        <thead>
          <tr>
            <th>Type</th>
            <th>Aantal</th>
            <th>Levering</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td><%= boeking.toestel?.type?.naam || '-' %></td>
            <td class="qty">1,00</td>
            <td><%= boeking.type || '-' %></td>
          </tr>
        </tbody>
      </table>
      <div class="row">
 <% if (boeking.comment && boeking.comment.trim() !== '') { %>
  <div class="opmerking-blok">
    <strong>Opmerkingen:</strong>
    <div class="opmerking">
      <%= boeking.comment %>
    </div>
  </div>
<% } %>
</div>
      <footer>
        BUMACO bv – Stationsstraat 216 – 3110 Rotselaar<br>
        Tel: 016/44.69.73 – Fax: 016/44.38.28 – E-mail: info@bumaco.be – www.bumaco.be<br>
        BTW BE 0455.064.414 – RPR Leuven
      </footer>
    </div>
  </div>
</body>
</html>